---
import { translations } from '../i18n/translations';

export interface Props {
  lang: string;
}

const { lang = 'en' } = Astro.props;
const t = translations[lang] || translations.en;
const year = new Date().getFullYear();
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<footer class="bg-walnut-950 text-sand-200">
  <div class="max-w-7xl mx-auto px-6 xl:px-0 py-20">
    <div class="grid grid-cols-1 md:grid-cols-6 gap-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <img src="/skydo-logo.jpg" alt="Skydo Home" class="h-10 md:h-14 w-auto brightness-0 invert opacity-80" />
        <p class="mt-4 text-sm text-sand-400 leading-relaxed max-w-xs font-light">
          {t.footer.description}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-[10px] tracking-[0.2em] uppercase text-sand-500 font-semibold mb-5">{t.footer.quickLinks}</h4>
        <div class="flex flex-col gap-3">
          {[
            { href: `${prefix}/`, label: t.nav.home },
            { href: `${prefix}/products`, label: t.nav.products },
            { href: `${prefix}/about`, label: t.nav.about },
            { href: `${prefix}/why-us`, label: t.nav.whyUs },
            { href: `${prefix}/contact`, label: t.nav.contact },
          ].map((link) => (
            <a href={link.href} class="text-sm text-sand-400 no-underline hover:text-sand-200 transition-colors font-light">{link.label}</a>
          ))}
        </div>
      </div>

      <!-- Categories -->
      <div>
        <h4 class="text-[10px] tracking-[0.2em] uppercase text-sand-500 font-semibold mb-5">{t.footer.categories}</h4>
        <div class="flex flex-col gap-3">
          {['Power Lift Recliners', 'Sofas & Sectionals', 'Motion Furniture', 'Swivel Chairs', 'Custom OEM'].map((cat) => (
            <a href={`${prefix}/products`} class="text-sm text-sand-400 no-underline hover:text-sand-200 transition-colors font-light">{cat}</a>
          ))}
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-[10px] tracking-[0.2em] uppercase text-sand-500 font-semibold mb-5">{t.footer.contact}</h4>
        <div class="flex flex-col gap-3 text-sm text-sand-400 font-light">
          <p>Saikodu (Foshan) Trading Co.</p>
          <p>Foshan, Guangdong, China</p>
          <a href="mailto:info@skydohome.com" class="no-underline text-sand-400 hover:text-sand-200 transition-colors">info@skydohome.com</a>
          <a href="tel:+861234567890" class="no-underline text-sand-400 hover:text-sand-200 transition-colors">+86 123 4567 890</a>
        </div>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-walnut-800/50 flex flex-col md:flex-row justify-between items-center gap-4 text-[11px] text-sand-600 font-light">
      <span>&copy; {year} {t.footer.copyright}</span>
      <span>{t.footer.tagline}</span>
    </div>
  </div>
</footer>
