---
const year = new Date().getFullYear();
---

<footer class="bg-charcoal-900 border-t border-charcoal-800/50">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <span class="text-2xl font-heading font-bold text-brass-400">SKYDO</span>
        <p class="mt-4 text-sm text-charcoal-400 leading-relaxed max-w-xs">
          Premium OEM/ODM furniture manufacturer based in Foshan, China. Crafting quality upholstered furniture for global B2B partners.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-xs tracking-[0.15em] uppercase text-brass-400 font-semibold mb-4">Quick Links</h4>
        <div class="flex flex-col gap-2.5">
          <a href="/" class="text-sm text-charcoal-400 no-underline hover:text-brass-300 transition-colors">Home</a>
          <a href="/products" class="text-sm text-charcoal-400 no-underline hover:text-brass-300 transition-colors">Products</a>
          <a href="/about" class="text-sm text-charcoal-400 no-underline hover:text-brass-300 transition-colors">About Us</a>
          <a href="/why-us" class="text-sm text-charcoal-400 no-underline hover:text-brass-300 transition-colors">Why Skydo</a>
          <a href="/contact" class="text-sm text-charcoal-400 no-underline hover:text-brass-300 transition-colors">Contact</a>
        </div>
      </div>

      <!-- Products -->
      <div>
        <h4 class="text-xs tracking-[0.15em] uppercase text-brass-400 font-semibold mb-4">Products</h4>
        <div class="flex flex-col gap-2.5">
          <a href="/products" class="text-sm text-charcoal-400 no-underline hover:text-brass-300 transition-colors">Power Lift Recliners</a>
          <a href="/products" class="text-sm text-charcoal-400 no-underline hover:text-brass-300 transition-colors">Sofas & Sectionals</a>
          <a href="/products" class="text-sm text-charcoal-400 no-underline hover:text-brass-300 transition-colors">Motion Furniture</a>
          <a href="/products" class="text-sm text-charcoal-400 no-underline hover:text-brass-300 transition-colors">Swivel Rocking Chairs</a>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-xs tracking-[0.15em] uppercase text-brass-400 font-semibold mb-4">Contact</h4>
        <div class="flex flex-col gap-2.5 text-sm text-charcoal-400">
          <span>Saikodu (Foshan) Trading Co., Ltd</span>
          <span>Foshan, Guangdong, China</span>
          <a href="mailto:info@skydohome.com" class="no-underline text-charcoal-400 hover:text-brass-300 transition-colors">info@skydohome.com</a>
          <a href="tel:+861234567890" class="no-underline text-charcoal-400 hover:text-brass-300 transition-colors">+86 123 4567 890</a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-charcoal-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-charcoal-600">
      <span>&copy; {year} Skydo Home. All rights reserved.</span>
      <span>OEM/ODM inquiries welcome</span>
    </div>
  </div>
</footer>
