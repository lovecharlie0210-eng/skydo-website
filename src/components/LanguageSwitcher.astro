---
import { languages } from '../i18n/languages';
export interface Props {
  currentLang: string;
  currentPath: string;
}
const { currentLang, currentPath } = Astro.props;
const lang = languages[currentLang] || languages.en;
---

<div class="relative" data-language-switcher>
  <button
    class="flex items-center gap-1.5 text-[11px] tracking-[0.1em] uppercase text-charcoal-500 hover:text-walnut-700 transition-colors cursor-pointer bg-transparent border-none py-1 px-0 font-medium"
    aria-label="Switch language"
    data-switcher-toggle
  >
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
    </svg>
    <span class="hidden sm:inline">{lang.nativeLabel}</span>
    <span class="sm:hidden">{currentLang.toUpperCase()}</span>
    <svg class="w-3 h-3 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-switcher-arrow>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </button>

  <div
    class="absolute right-0 top-full mt-1 bg-white border border-sand-200 shadow-lg min-w-[140px] hidden z-50"
    data-switcher-menu
  >
    {Object.entries(languages).map(([code, langData]) => (
      code !== currentLang ? (
        <a
          href={code === 'en' ? `/en${currentPath}` : `/${code}${currentPath}`}
          class="block px-4 py-2.5 text-xs text-charcoal-600 no-underline hover:bg-sand-50 hover:text-walnut-700 transition-colors font-medium"
          data-lang-option
          data-lang-code={code}
        >
          {langData.nativeLabel}
        </a>
      ) : null
    ))}
  </div>
</div>

<script>
  const container = document.querySelector('[data-language-switcher]');
  if (container) {
    const toggle = container.querySelector('[data-switcher-toggle]');
    const menu = container.querySelector('[data-switcher-menu]');
    const arrow = container.querySelector('[data-switcher-arrow]');

    toggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      menu?.classList.toggle('hidden');
      arrow?.classList.toggle('rotate-180');
    });

    document.addEventListener('click', () => {
      menu?.classList.add('hidden');
      arrow?.classList.remove('rotate-180');
    });

    // Save selected language to localStorage before navigation
    container.querySelectorAll('[data-lang-option]').forEach((el) => {
      el.addEventListener('click', () => {
        localStorage.setItem('skydo-lang', el.getAttribute('data-lang-code'));
      });
    });
  }
</script>
