---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/about', label: 'About' },
  { href: '/why-us', label: 'Why Skydo' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 nav-glass">
  <nav class="max-w-7xl mx-auto px-6 xl:px-0 h-[72px] flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 no-underline">
      <span class="text-2xl font-heading text-walnut-700 font-medium tracking-tight">Skydo</span>
      <span class="hidden sm:inline text-[10px] tracking-[0.2em] uppercase text-charcoal-400 pt-0.5 font-medium border-l border-sand-300 pl-3">Furniture</span>
    </a>
    <div class="hidden md:flex items-center gap-10">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-xs tracking-[0.15em] uppercase text-charcoal-600 no-underline link-hover font-medium"
        >
          {link.label}
        </a>
      ))}
      <a href="/contact" class="btn-primary !py-2.5 !px-6 !text-[11px]">Get a Quote</a>
    </div>
    <!-- Mobile menu button -->
    <button id="menu-toggle" class="md:hidden flex flex-col gap-1 p-2 cursor-pointer bg-transparent border-none" aria-label="Toggle menu">
      <span class="block w-5 h-[1.5px] bg-walnut-700 transition-all"></span>
      <span class="block w-4 h-[1.5px] bg-walnut-700 transition-all"></span>
      <span class="block w-5 h-[1.5px] bg-walnut-700 transition-all"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden nav-glass">
    <div class="px-6 py-8 flex flex-col gap-5">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm tracking-[0.15em] uppercase text-charcoal-600 no-underline hover:text-walnut-700 transition-colors font-medium"
        >
          {link.label}
        </a>
      ))}
      <a href="/contact" class="btn-primary text-center mt-2">Get a Quote</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
