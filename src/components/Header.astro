---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/about', label: 'About' },
  { href: '/why-us', label: 'Why Skydo' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 glass">
  <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 no-underline">
      <span class="text-2xl font-heading font-bold text-brass-400">SKYDO</span>
      <span class="hidden sm:inline text-xs tracking-[0.2em] uppercase text-charcoal-400 pt-1">Home</span>
    </a>
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm tracking-wider uppercase text-charcoal-300 no-underline link-underline transition-colors hover:text-brass-300"
        >
          {link.label}
        </a>
      ))}
      <a href="/contact" class="btn-brass !py-2 !px-5 !text-xs">Get a Quote</a>
    </div>
    <!-- Mobile menu button -->
    <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer bg-transparent border-none" aria-label="Toggle menu">
      <span class="block w-6 h-px bg-brass-400 transition-all"></span>
      <span class="block w-5 h-px bg-brass-400 transition-all"></span>
      <span class="block w-6 h-px bg-brass-400 transition-all"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden">
    <div class="px-6 py-6 flex flex-col gap-4 border-t border-charcoal-800">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm tracking-wider uppercase text-charcoal-300 no-underline hover:text-brass-300 transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a href="/contact" class="btn-brass text-center mt-2">Get a Quote</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      toggle.classList.toggle('active');
    });
  }
</script>
