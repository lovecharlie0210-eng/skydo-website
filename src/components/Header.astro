---
import { translations } from '../i18n/translations';
import { locales } from '../i18n/languages';
import LanguageSwitcher from './LanguageSwitcher.astro';

export interface Props {
  lang: string;
}

const { lang = 'en' } = Astro.props;
const t = translations[lang] || translations.en;
const linkPrefix = lang === 'en' ? '' : `/${lang}`;

const navLinks = [
  { href: `${linkPrefix}/`, label: t.nav.home },
  { href: `${linkPrefix}/products`, label: t.nav.products },
  { href: `${linkPrefix}/about`, label: t.nav.about },
  { href: `${linkPrefix}/why-us`, label: t.nav.whyUs },
  { href: `${linkPrefix}/contact`, label: t.nav.contact },
];

const pathMap = {
  '/': '/',
  '/products': '/products',
  '/about': '/about',
  '/why-us': '/why-us',
  '/contact': '/contact',
};

// currentPath without language prefix, for the language switcher
const url = new URL(Astro.url);
const segments = url.pathname.split('/').filter(Boolean);
// Remove lang prefix if it matches a locale
const currentPath = segments.length > 0 && segments[0] === lang ? '/' + segments.slice(1).join('/') : url.pathname;
---
<header class="fixed top-0 left-0 right-0 z-50 nav-glass">
  <nav class="max-w-7xl mx-auto px-6 xl:px-0 h-[72px] flex items-center justify-between">
    <a href="/en" class="flex items-center gap-3 no-underline">
      <img src="/skydo-logo.jpg" alt="Skydo Home" class="h-10 md:h-12 w-auto" />
      <span class="hidden sm:inline text-[10px] tracking-[0.2em] uppercase text-charcoal-400 pt-0.5 font-medium border-l border-sand-300 pl-3">{t.nav.furniture}</span>
    </a>
    <div class="hidden md:flex items-center gap-10">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-xs tracking-[0.15em] uppercase text-charcoal-600 no-underline link-hover font-medium"
        >
          {link.label}
        </a>
      ))}
      <LanguageSwitcher currentLang={lang} currentPath={currentPath} />
      <a href={`${linkPrefix}/contact`} class="btn-primary !py-2.5 !px-6 !text-[11px]">{t.nav.getQuote}</a>
    </div>
    <!-- Mobile menu button -->
    <button id="menu-toggle" class="md:hidden flex flex-col gap-1 p-2 cursor-pointer bg-transparent border-none" aria-label="Toggle menu">
      <span class="block w-5 h-[1.5px] bg-walnut-700 transition-all"></span>
      <span class="block w-4 h-[1.5px] bg-walnut-700 transition-all"></span>
      <span class="block w-5 h-[1.5px] bg-walnut-700 transition-all"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden nav-glass">
    <div class="px-6 py-8 flex flex-col gap-5">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm tracking-[0.15em] uppercase text-charcoal-600 no-underline hover:text-walnut-700 transition-colors font-medium"
        >
          {link.label}
        </a>
      ))}
      <div class="flex items-center gap-3 pt-2 border-t border-sand-200">
        <span class="text-[10px] tracking-[0.1em] uppercase text-charcoal-400 font-medium">Language:</span>
        {[{ code: 'en', label: 'EN' }, { code: 'es', label: 'ES' }, { code: 'fr', label: 'FR' }, { code: 'de', label: 'DE' }, { code: 'pt', label: 'PT' }].map((l) => (
          <a
            href={l.code === 'en' ? `/en${currentPath}` : `/${l.code}${currentPath}`}
            class={`text-[11px] tracking-wider uppercase no-underline px-2 py-0.5 transition-colors ${lang === l.code ? 'text-walnut-700 bg-sand-100 font-semibold' : 'text-charcoal-500 hover:text-walnut-600 font-medium'}`}
          >
            {l.label}
          </a>
        ))}
      </div>
      <a href={`${linkPrefix}/contact`} class="btn-primary text-center mt-2">{t.nav.getQuote}</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
