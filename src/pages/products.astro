---
import Layout from '../layouts/Layout.astro';

const categories = [
  { name: 'Power Lift Recliners', desc: 'Dual-motor, genuine leather, heat & massage options. Our best-selling category dominating the US market.', slug: 'power-lift' },
  { name: 'Sofas & Sectionals', desc: 'Fabric and leather sofas, sectionals, and sleeper sofas. Custom sizes, colors, and configurations available.', slug: 'sofas' },
  { name: 'Motion Furniture', desc: 'Reclining sofas, wall-hugger mechanisms, zero-gravity positions. Comfort engineered for daily living.', slug: 'motion' },
  { name: 'Swivel Rocking Chairs', desc: 'Glider-swivel combinations, nursery-grade smooth motion, upholstered in fabric or bonded leather.', slug: 'swivel' },
  { name: 'Accent Chairs', desc: 'Club chairs, wingback chairs, occasional seating. Perfect for hospitality and residential projects.', slug: 'accent' },
  { name: 'Custom OEM Projects', desc: 'Your design, our manufacturing. From concept to container — full product development support.', slug: 'custom' },
];
---

<Layout title="Products — Upholstered Furniture Collection">
  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-charcoal-950 via-charcoal-950 to-charcoal-900"></div>
    <div class="absolute inset-0 texture-overlay"></div>
    <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-brass-500/5 rounded-full blur-[100px]"></div>
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="max-w-2xl">
        <p class="text-xs tracking-[0.25em] uppercase text-brass-400 font-semibold">Our Collection</p>
        <h1 class="mt-4 text-4xl md:text-6xl font-heading font-bold text-charcoal-100 leading-tight">
          Upholstered<br />
          <span class="italic text-brass-400">Furniture Range</span>
        </h1>
        <p class="mt-6 text-charcoal-400 text-sm leading-relaxed max-w-xl">
          From power lift recliners to custom contract furniture — explore our full range of upholstered products. Replace images with your own product photography.
        </p>
      </div>
    </div>
  </section>

  <!-- Product Categories -->
  <section class="relative pb-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {categories.map((cat, i) => (
          <div class="group bg-charcoal-900/50 border border-charcoal-800/50 overflow-hidden transition-all duration-500 hover:border-brass-500/30 card-hover">
            <div class="aspect-[4/3] bg-gradient-to-br from-charcoal-800 to-charcoal-900 flex items-center justify-center overflow-hidden">
              <div class="text-center p-6">
                <svg class="w-12 h-12 mx-auto text-brass-400/40 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M8.25 3.75l-1.5 3.75m9-3.75l1.5 3.75M9 13.5h6" />
                </svg>
                <p class="text-xs text-charcoal-600 uppercase tracking-wider">[ Your Product Image ]</p>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-lg font-heading font-bold text-charcoal-100 group-hover:text-brass-300 transition-colors">{cat.name}</h3>
              <p class="mt-2 text-sm text-charcoal-500 leading-relaxed">{cat.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 bg-charcoal-900/50 border-t border-charcoal-800/50">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-4xl font-heading font-bold text-charcoal-100">
        Need a <span class="italic text-brass-400">Custom</span> Product?
      </h2>
      <p class="mt-4 text-charcoal-400 text-sm">
        We develop OEM products from your sketches, specs, or reference samples. Send us your requirements.
      </p>
      <a href="/contact" class="btn-brass mt-8">Submit Your Inquiry</a>
    </div>
  </section>
</Layout>
