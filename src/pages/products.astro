---
import Layout from '../layouts/Layout.astro';

const categories = [
  { name: 'Power Lift Recliners', desc: 'Dual-motor, genuine leather, heat & massage options. Our best-selling category dominating the US market.', slug: 'power-lift' },
  { name: 'Sofas & Sectionals', desc: 'Fabric and leather sofas, sectionals, sleeper sofas. Custom sizes, colors, and configurations.', slug: 'sofas' },
  { name: 'Motion Furniture', desc: 'Reclining sofas, wall-hugger mechanisms, zero-gravity positions. Comfort engineered for daily living.', slug: 'motion' },
  { name: 'Swivel Rocking Chairs', desc: 'Glider-swivel combinations, smooth motion, upholstered in fabric or bonded leather.', slug: 'swivel' },
  { name: 'Accent Chairs', desc: 'Club chairs, wingbacks, occasional seating. Perfect for hospitality and residential.', slug: 'accent' },
  { name: 'Custom OEM', desc: 'Your design, our manufacturing. From concept to container — full product development support.', slug: 'custom' },
];
---

<Layout title="Products — Upholstered Furniture">
  <section class="pt-[120px] pb-20 bg-sand-50/50">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="max-w-2xl">
        <div class="accent-line"></div>
        <h1 class="mt-6 text-4xl md:text-6xl text-walnut-950 leading-tight">
          Our<br />
          <span class="italic text-walnut-500">Collection</span>
        </h1>
        <p class="mt-4 text-sm text-charcoal-500 leading-relaxed font-light max-w-lg">
          Explore our range of upholstered furniture designed for global B2B markets. Replace placeholder areas with your product photography.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-28">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 -mt-8">
        {categories.map((cat) => (
          <div class="bg-white border border-sand-200 overflow-hidden transition-all duration-300 card-hover">
            <div class="aspect-[4/3] product-image-area flex items-center justify-center">
              <div class="text-center p-6">
                <svg class="w-10 h-10 mx-auto text-sand-400/60 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M8.25 3.75l-1.5 3.75m9-3.75l1.5 3.75M9 13.5h6" />
                </svg>
                <p class="text-[10px] text-charcoal-400 uppercase tracking-wider font-medium">[ Your Image ]</p>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-lg font-heading text-walnut-800">{cat.name}</h3>
              <p class="mt-2 text-xs text-charcoal-500 leading-relaxed font-light">{cat.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-sand-50 border-t border-sand-200">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div class="accent-line mx-auto"></div>
      <h2 class="mt-5 text-2xl md:text-4xl text-walnut-950">
        Need a <span class="italic text-walnut-500">Custom</span> Product?
      </h2>
      <p class="mt-4 text-sm text-charcoal-500 font-light">
        We develop OEM products from your sketches, specs, or samples. Tell us what you need.
      </p>
      <a href="/contact" class="btn-primary mt-8">Submit Inquiry</a>
    </div>
  </section>
</Layout>
