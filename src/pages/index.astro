---
const localesStr = JSON.stringify(['en', 'es', 'fr', 'de', 'pt']);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Skydo Home — Premium OEM/ODM Furniture Manufacturer</title>
    <meta name="description" content="Skydo Home — Premium OEM/ODM Furniture Manufacturer from Foshan, China. Specializing in upholstered furniture for global B2B partners." />
    <meta name="robots" content="noindex, follow" />
  </head>
  <body>
    <p>Redirecting to your preferred language...</p>
    <script>
      (function() {
        var supported = {localesStr};
        var saved = localStorage.getItem('skydo-lang');
        var lang = saved;

        if (!lang) {
          var browserLang = (navigator.language || '').split('-')[0];
          if (supported.indexOf(browserLang) !== -1) {
            lang = browserLang;
          } else {
            lang = 'en';
          }
        }

        if (!saved) {
          try { localStorage.setItem('skydo-lang', lang); } catch(e) {}
        }

        window.location.replace('/' + lang + '/');
      })();
    </script>
    <noscript>
      <meta http-equiv="refresh" content="0;url=/en/" />
    </noscript>
  </body>
</html>
