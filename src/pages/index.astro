---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Premium OEM/ODM Furniture Manufacturer">
  <!-- ========== Hero ========== -->
  <section class="relative min-h-screen flex items-center pt-16 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-charcoal-950 via-charcoal-950 to-charcoal-900"></div>
    <div class="absolute inset-0 texture-overlay"></div>
    <div class="absolute top-1/4 right-0 w-[600px] h-[600px] bg-brass-500/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-1/4 left-0 w-[400px] h-[400px] bg-brass-400/5 rounded-full blur-[100px]"></div>

    <div class="relative max-w-7xl mx-auto px-6 py-24 w-full">
      <div class="max-w-3xl">
        <p class="text-brass-400 tracking-[0.25em] text-sm uppercase font-medium animate-fade-in">OEM / ODM Furniture Manufacturer</p>
        <h1 class="mt-6 text-5xl md:text-7xl lg:text-8xl font-heading font-bold text-charcoal-100 leading-[1.05] tracking-tight animate-fade-in-up">
          Your Trusted<br />
          <span class="text-brass-400 italic">Furniture</span><br />
        </h1>
        <p class="mt-2 text-3xl md:text-4xl font-heading font-bold text-charcoal-200 animate-fade-in-up delay-100">Manufacturing Partner</p>
        <p class="mt-6 text-lg text-charcoal-400 leading-relaxed max-w-xl animate-fade-in-up delay-200">
          Based in Foshan, China — the heart of furniture manufacturing. We deliver premium upholstered furniture with 20 years of craftsmanship expertise.
        </p>
        <div class="mt-10 flex flex-wrap gap-4 animate-fade-in-up delay-300">
          <a href="/contact" class="btn-brass">Send Inquiry</a>
          <a href="/products" class="btn-outline">View Products</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Stats Bar ========== -->
  <section class="relative border-y border-charcoal-800/50">
    <div class="max-w-7xl mx-auto px-6 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {[
          { number: '20+', label: 'Years of Furniture Expertise' },
          { number: '500K+', label: 'Units Shipped Globally' },
          { number: '30+', label: 'Export Countries' },
          { number: '200+', label: 'Skilled Craftspersons' },
        ].map((stat) => (
          <div class="text-center">
            <p class="text-3xl md:text-4xl font-heading font-bold text-brass-400">{stat.number}</p>
            <p class="mt-2 text-xs tracking-wider uppercase text-charcoal-500">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== Categories ========== -->
  <section class="relative py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs tracking-[0.25em] uppercase text-brass-400 font-semibold">Our Range</p>
        <h2 class="mt-4 text-3xl md:text-5xl font-heading font-bold text-charcoal-100">
          Upholstered Furniture<br /><span class="italic text-brass-400">Collections</span>
        </h2>
        <p class="mt-4 text-charcoal-400 text-sm leading-relaxed">
          From power lift recliners to custom sofas — our factory delivers quality motion and stationary upholstered furniture for global B2B buyers.
        </p>
      </div>

      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Power Lift Recliner -->
        <div class="group relative overflow-hidden card-hover cursor-pointer">
          <div class="aspect-[3/4] bg-gradient-to-br from-charcoal-800 to-charcoal-900 flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-16 h-16 mx-auto rounded-full brass-gradient flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-charcoal-950" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m6 4.125l2.25 2.25m0 0l2.25-2.25M12 13.875V7.5M4.875 7.5h14.25" /></svg>
              </div>
              <h3 class="text-xl font-heading font-bold text-charcoal-100 group-hover:text-brass-300 transition-colors">Power Lift Recliners</h3>
              <p class="mt-3 text-sm text-charcoal-500 leading-relaxed">
                Dual motor, premium leather. The #1 bestselling category in the US market.
              </p>
            </div>
          </div>
        </div>

        <!-- Sofas & Sectionals -->
        <div class="group relative overflow-hidden card-hover cursor-pointer">
          <div class="aspect-[3/4] bg-gradient-to-br from-charcoal-800 to-charcoal-900 flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-16 h-16 mx-auto rounded-full bg-charcoal-700 flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-brass-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
              </div>
              <h3 class="text-xl font-heading font-bold text-charcoal-100 group-hover:text-brass-300 transition-colors">Sofas & Sectionals</h3>
              <p class="mt-3 text-sm text-charcoal-500 leading-relaxed">
                Custom designs, fabric & leather options. Built for durability and style.
              </p>
            </div>
          </div>
        </div>

        <!-- Motion & Swivel -->
        <div class="group relative overflow-hidden card-hover cursor-pointer">
          <div class="aspect-[3/4] bg-gradient-to-br from-charcoal-800 to-charcoal-900 flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-16 h-16 mx-auto rounded-full bg-charcoal-700 flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-brass-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 11-.99-3.467l2.31-.66a2.25 2.25 0 001.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 01-.99-3.467l2.31-.66A2.25 2.25 0 009 15.553z" /></svg>
              </div>
              <h3 class="text-xl font-heading font-bold text-charcoal-100 group-hover:text-brass-300 transition-colors">Motion & Swivel Chairs</h3>
              <p class="mt-3 text-sm text-charcoal-500 leading-relaxed">
                Rocking, swiveling, gliding — comfort mechanisms for every need.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Why Skydo Preview ========== -->
  <section class="relative py-24 md:py-32 bg-charcoal-900/50">
    <div class="absolute inset-0 texture-overlay"></div>
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs tracking-[0.25em] uppercase text-brass-400 font-semibold">Why Skydo</p>
          <h2 class="mt-4 text-3xl md:text-5xl font-heading font-bold text-charcoal-100 leading-tight">
            A Factory That<br />
            <span class="italic text-brass-400">Delivers</span>
          </h2>
          <p class="mt-6 text-charcoal-400 text-sm leading-relaxed">
            Skydo is the OEM/ODM arm of a factory that supplies China's top furniture brands — including Kuka (formerly Man Wah Holdings) and Oupai. We combine two decades of manufacturing expertise with modern production capabilities.
          </p>
          <ul class="mt-8 space-y-4">
            {[
              'Direct factory pricing — no middlemen',
              'Strict QC: 3-stage inspection process',
              'BSCI, ISO, and international safety compliance',
              'FOB Guangzhou, flexible MOQ for partners',
              'R&D team for custom product development',
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm text-charcoal-300">
                <span class="mt-0.5 w-1.5 h-1.5 rounded-full bg-brass-500 flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
          <a href="/why-us" class="btn-outline mt-10">Discover Our Advantages</a>
        </div>
        <div class="relative">
          <div class="aspect-square max-w-md mx-auto w-full rounded-sm overflow-hidden bg-gradient-to-br from-charcoal-800 to-charcoal-700 p-1">
            <div class="w-full h-full bg-gradient-to-br from-charcoal-700 via-charcoal-800 to-charcoal-900 rounded-sm flex items-center justify-center">
              <div class="text-center">
                <span class="text-5xl font-heading font-bold text-brass-400/30">20</span>
                <p class="text-xs tracking-wider uppercase text-charcoal-600 mt-2">Years of Excellence</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="relative py-24 md:py-32">
    <div class="absolute inset-0 bg-gradient-to-b from-charcoal-900/0 via-charcoal-900/50 to-charcoal-950"></div>
    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-5xl font-heading font-bold text-charcoal-100 leading-tight">
        Ready to Partner<br />
        <span class="italic text-brass-400">with Skydo?</span>
      </h2>
      <p class="mt-6 text-charcoal-400 text-sm leading-relaxed max-w-lg mx-auto">
        Whether you need custom OEM production or ready-made wholesale products, our team is ready to support your business.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/contact" class="btn-brass text-sm">Request a Catalog</a>
        <a href="/about" class="btn-outline text-sm">Learn About Our Factory</a>
      </div>
    </div>
  </section>
</Layout>
