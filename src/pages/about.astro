---
import Layout from '../layouts/Layout.astro';

const timeline = [
  { year: '2005', event: 'Factory founded in Foshan, specializing in upholstered furniture production for the domestic market.' },
  { year: '2010', event: 'Became OEM partner for Kuka (formerly Man Wah Holdings), China\'s largest publicly traded furniture manufacturer.' },
  { year: '2015', event: 'Expanded production with dedicated motion furniture and power mechanism assembly lines.' },
  { year: '2018', event: 'Launched export operations to North American and European B2B partners.' },
  { year: '2020', event: 'Skydo brand established for direct B2B OEM/ODM partnerships. BSCI certification achieved.' },
  { year: '2024', event: 'Strategic focus on power lift recliner specialization. Surpassed 500,000 cumulative units shipped globally.' },
];

const certs = ['BSCI', 'ISO 9001', 'UL/ETL Mechanisms', 'CA Prop 65', 'FSC Packaging'];
---

<Layout title="About — Our Factory">
  <section class="pt-[120px] pb-20 bg-sand-50/50">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="max-w-2xl">
        <div class="accent-line"></div>
        <h1 class="mt-6 text-4xl md:text-6xl text-walnut-950 leading-tight">
          From Foshan,<br />
          <span class="italic text-walnut-500">To the World</span>
        </h1>
      </div>
    </div>
  </section>

  <section class="pb-28">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <h2 class="text-2xl md:text-4xl font-heading text-walnut-950">
            A Legacy of<br />
            <span class="italic text-walnut-500">Craftsmanship</span>
          </h2>
          <div class="mt-6 space-y-4 text-sm text-charcoal-500 leading-relaxed font-light">
            <p>
              Skydo is the B2B export division of a Foshan-based factory with two decades of furniture manufacturing heritage. Our production lines have supplied China's top furniture brands and served international buyers across 30+ countries.
            </p>
            <p>
              Our facility features automated fabric cutting, precision framing, professional upholstery workstations, and a multi-stage quality inspection system. With an annual output exceeding 50,000 units, we are equipped to scale with your business.
            </p>
            <p>
              What distinguishes us: we don't just manufacture to specification — we contribute design insight, material expertise, and market intelligence to every OEM/ODM partnership.
            </p>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] img-upload-area flex items-center justify-center">
            <div class="text-center">
              <svg class="w-24 h-24 mx-auto text-sand-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 21h18M3.75 3v18M20.25 3v18M6.75 3h10.5M6.75 7.5h.75m-.75 3.75h.75m-.75 3.75h.75m3-11.25h.75m-.75 3.75h.75m-.75 3.75h.75m3-11.25h.75m-.75 3.75h.75m-.75 3.75h.75M6.75 21V3m10.5 18V3" />
              </svg>
              <p class="text-sm text-walnut-500 font-medium">📷 Factory Image</p>
              <p class="text-xs text-charcoal-400 mt-1">Replace with your factory photo</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-sand-50">
    <div class="max-w-4xl mx-auto px-6 xl:px-0">
      <div class="text-center">
        <div class="accent-line mx-auto"></div>
        <h2 class="mt-5 text-2xl md:text-4xl font-heading text-walnut-950">
          Our <span class="italic text-walnut-500">Journey</span>
        </h2>
      </div>
      <div class="mt-14">
        {timeline.map((item, i) => (
          <div class="flex gap-6">
            <div class="flex flex-col items-center">
              <div class="w-3 h-3 rounded-full border-2 border-walnut-400 bg-white mt-1"></div>
              {i < timeline.length - 1 && <div class="w-px flex-1 bg-sand-200"></div>}
            </div>
            <div class="pb-10">
              <span class="text-xs tracking-[0.15em] uppercase text-walnut-600 font-semibold">{item.year}</span>
              <p class="mt-1.5 text-sm text-charcoal-600 leading-relaxed font-light">{item.event}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="max-w-4xl mx-auto px-6 xl:px-0 text-center">
      <div class="accent-line mx-auto"></div>
      <h2 class="mt-5 text-2xl md:text-4xl font-heading text-walnut-950">
        Certifications & <span class="italic text-walnut-500">Compliance</span>
      </h2>
      <p class="mt-3 text-sm text-charcoal-500 font-light mb-10">Meeting international standards for safety, quality, and social responsibility.</p>
      <div class="flex flex-wrap justify-center gap-3">
        {certs.map((cert) => (
          <span class="px-5 py-2.5 border border-sand-300 text-xs text-charcoal-600 bg-sand-50 tracking-wider font-medium">{cert}</span>
        ))}
      </div>
    </div>
  </section>
</Layout>
