---
import Layout from '../layouts/Layout.astro';

const advantages = [
  {
    icon: 'M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12',
    title: 'Full OEM/ODM Capability',
    desc: 'From concept sketches to finished products. Our R&D team works with your specifications to create custom furniture that meets your market requirements.',
    details: ['3D modeling & prototyping', 'Custom material sourcing', 'Packaging & labeling design', 'Private label options'],
  },
  {
    icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
    title: '3-Stage Quality Control',
    desc: 'Every product passes raw material inspection, in-production checks, and final pre-shipment testing before leaving our factory.',
    details: ['Raw material testing', 'In-line production QC', 'AQL 2.5 final inspection', '1-year mechanism warranty'],
  },
  {
    icon: 'M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5',
    title: 'Flexible Terms & MOQ',
    desc: 'We work with partners at every scale — from trial orders to full container loads. Transparent pricing and flexible terms.',
    details: ['MOQ from 50 units', 'Mix container options', 'FOB/CIF/DDP terms', '30/70 payment terms'],
  },
  {
    icon: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75',
    title: 'Market-Ready Design',
    desc: 'Our products are designed for the US, UK, and Australian markets — meeting local compliance, sizing, and consumer preferences.',
    details: ['UL/ETL certified mechanisms', 'CA Prop 65 compliant', 'UK regulations met', 'Australian standards'],
  },
  {
    icon: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0zM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z',
    title: 'Foshan Factory Advantage',
    desc: 'Located 30 minutes from Guangzhou ports. Our logistics team handles consolidation, documentation, and shipping coordination.',
    details: ['30 min to port', 'Container loading supervision', 'Export docs included', 'Global shipping partners'],
  },
  {
    icon: 'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Direct Factory Pricing',
    desc: 'Deal directly with the manufacturer — no trading company markups, faster communication, total transparency.',
    details: ['No middleman margins', 'Volume-based discounts', 'Price protection for partners', 'Direct communication'],
  },
];
---

<Layout title="Why Skydo — OEM/ODM Advantages">
  <section class="pt-[120px] pb-20 bg-sand-50/50">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="max-w-2xl">
        <div class="accent-line"></div>
        <h1 class="mt-6 text-4xl md:text-6xl text-walnut-950 leading-tight">
          A Better Way to<br />
          <span class="italic text-walnut-500">Source Furniture</span>
        </h1>
        <p class="mt-4 text-sm text-charcoal-500 leading-relaxed font-light max-w-lg">
          Direct factory partnership means better quality, clearer communication, and pricing that reflects real manufacturing costs.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-28">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 -mt-8">
        {advantages.map((adv) => (
          <div class="bg-white border border-sand-200 p-8 card-hover">
            <svg class="w-7 h-7 text-walnut-500 mb-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={adv.icon} />
            </svg>
            <h3 class="text-lg font-heading text-walnut-800">{adv.title}</h3>
            <p class="mt-3 text-xs text-charcoal-500 leading-relaxed font-light">{adv.desc}</p>
            <ul class="mt-4 space-y-1.5">
              {adv.details.map((d) => (
                <li class="flex items-center gap-2 text-[11px] text-charcoal-400">
                  <span class="w-1 h-1 bg-walnut-300 rounded-full"></span>
                  {d}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-sand-50 border-t border-sand-200">
    <div class="max-w-5xl mx-auto px-6 xl:px-0">
      <div class="text-center">
        <div class="accent-line mx-auto"></div>
        <h2 class="mt-5 text-2xl md:text-4xl font-heading text-walnut-950">
          How We <span class="italic text-walnut-500">Partner</span>
        </h2>
      </div>
      <div class="mt-14 grid grid-cols-1 md:grid-cols-4 gap-10">
        {[
          { step: '01', title: 'Inquiry', desc: 'Share your requirements, target pricing, and timeline.' },
          { step: '02', title: 'Quotation', desc: 'Detailed specs, pricing, and lead time within 48 hours.' },
          { step: '03', title: 'Sampling', desc: 'Sample production with photo/video approval. Revisions included.' },
          { step: '04', title: 'Production', desc: 'Bulk manufacturing with QC inspection at every stage.' },
        ].map((item) => (
          <div class="text-center">
            <span class="text-5xl font-heading text-walnut-200/70">{item.step}</span>
            <h3 class="mt-4 text-lg font-heading text-walnut-800">{item.title}</h3>
            <p class="mt-2 text-xs text-charcoal-500 font-light">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/contact" class="btn-primary">Start Your Partnership</a>
      </div>
    </div>
  </section>
</Layout>
