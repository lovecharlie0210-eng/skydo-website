---
import Layout from '../layouts/Layout.astro';

const advantages = [
  {
    icon: 'factory',
    title: 'Full OEM/ODM Capability',
    desc: 'From concept sketches to finished products. Our R&D team works with your specifications to create custom furniture that meets your market requirements.',
    details: ['3D modeling & prototyping', 'Custom material sourcing', 'Packaging & labeling design', 'Private label options'],
  },
  {
    icon: 'quality',
    title: '3-Stage Quality Control',
    desc: 'Every product passes raw material inspection, in-production checks, and final pre-shipment inspection before leaving our factory.',
    details: ['Raw material testing', 'In-line production QC', 'Final random inspection (AQL 2.5)', '1-year warranty on mechanisms'],
  },
  {
    icon: 'flex',
    title: 'Flexible MOQ & Terms',
    desc: 'We work with partners at every scale — from trial orders to full container loads. FOB Guangzhou, CIF, or DDP terms available.',
    details: ['MOQ from 50 units (trial order)', 'Mix container options', 'FOB/CIF/DDP terms', '30% deposit, 70% before shipment'],
  },
  {
    icon: 'market',
    title: 'Market-Ready Product Design',
    desc: 'Our products are designed for the US, UK, and Australian markets — meeting local compliance, sizing, and consumer preferences.',
    details: ['UL/ETL certified mechanisms', 'CA Prop 65 compliant materials', 'UK furniture regulations met', 'Australian standards compliant'],
  },
  {
    icon: 'logistics',
    title: 'Efficient Logistics Network',
    desc: 'Located in Foshan, 30 minutes from Guangzhou ports. Our logistics team handles consolidation, documentation, and shipping coordination.',
    details: ['Foshan factory to port in 30 min', 'Container loading supervision', 'Export documentation included', 'Global shipping partners'],
  },
  {
    icon: 'cost',
    title: 'Direct Factory Pricing',
    desc: 'No trading company markups. You deal directly with the factory — better pricing, faster communication, total transparency.',
    details: ['Direct factory pricing', 'No middleman fees', 'Volume-based discounts', 'Price protection for long-term partners'],
  },
];

const iconMap: Record<string, string> = {
  factory: 'M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12',
  quality: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
  flex: 'M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5',
  market: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z',
  logistics: 'M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12',
  cost: 'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
};
---

<Layout title="Why Skydo — OEM/ODM Furniture Manufacturer">
  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-charcoal-950 via-charcoal-950 to-charcoal-900"></div>
    <div class="absolute inset-0 texture-overlay"></div>
    <div class="absolute top-1/3 left-0 w-[400px] h-[400px] bg-brass-500/5 rounded-full blur-[100px]"></div>
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="max-w-3xl">
        <p class="text-xs tracking-[0.25em] uppercase text-brass-400 font-semibold">Why Skydo</p>
        <h1 class="mt-4 text-4xl md:text-6xl font-heading font-bold text-charcoal-100 leading-tight">
          A Better Way to<br />
          <span class="italic text-brass-400">Source Furniture</span>
        </h1>
        <p class="mt-6 text-charcoal-400 text-sm leading-relaxed max-w-xl">
          Direct factory partnership means better quality control, clearer communication, and pricing that reflects real manufacturing costs — not middleman margins.
        </p>
      </div>
    </div>
  </section>

  <!-- Advantages Grid -->
  <section class="relative pb-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {advantages.map((adv) => (
          <div class="bg-charcoal-900/50 border border-charcoal-800/50 p-8 card-hover">
            <svg class="w-8 h-8 text-brass-400 mb-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconMap[adv.icon]} />
            </svg>
            <h3 class="text-lg font-heading font-bold text-charcoal-100">{adv.title}</h3>
            <p class="mt-3 text-sm text-charcoal-500 leading-relaxed">{adv.desc}</p>
            <ul class="mt-4 space-y-1.5">
              {adv.details.map((d) => (
                <li class="flex items-center gap-2 text-xs text-charcoal-500">
                  <span class="w-1 h-1 rounded-full bg-brass-500"></span>
                  {d}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="relative py-24 bg-charcoal-900/50 border-t border-charcoal-800/50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center">
        <h2 class="text-2xl md:text-4xl font-heading font-bold text-charcoal-100">
          How We <span class="italic text-brass-400">Partner</span>
        </h2>
      </div>
      <div class="mt-12 grid grid-cols-1 md:grid-cols-4 gap-6">
        {[
          { step: '01', title: 'Inquiry', desc: 'Share your requirements, target price point, and timeline.' },
          { step: '02', title: 'Quotation', desc: 'We provide detailed specs, pricing, and lead time within 48 hours.' },
          { step: '03', title: 'Sampling', desc: 'Sample production, photo & video approval, revisions included.' },
          { step: '04', title: 'Production', desc: 'Bulk manufacturing with QC inspections at every stage.' },
        ].map((item) => (
          <div class="text-center">
            <span class="text-4xl font-heading font-bold text-brass-500/30">{item.step}</span>
            <h3 class="mt-3 text-lg font-heading font-bold text-charcoal-100">{item.title}</h3>
            <p class="mt-2 text-sm text-charcoal-500">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/contact" class="btn-brass">Start Your Partnership</a>
      </div>
    </div>
  </section>
</Layout>
