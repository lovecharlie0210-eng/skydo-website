---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Get in Touch">
  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-charcoal-950 via-charcoal-950 to-charcoal-900"></div>
    <div class="absolute inset-0 texture-overlay"></div>
    <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-brass-500/5 rounded-full blur-[100px]"></div>
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="max-w-2xl">
        <p class="text-xs tracking-[0.25em] uppercase text-brass-400 font-semibold">Contact</p>
        <h1 class="mt-4 text-4xl md:text-6xl font-heading font-bold text-charcoal-100 leading-tight">
          Let's Start a<br />
          <span class="italic text-brass-400">Conversation</span>
        </h1>
        <p class="mt-6 text-charcoal-400 text-sm leading-relaxed">
          Tell us about your project — product type, target market, volume, and timeline. We'll get back to you within 24 hours with a competitive quotation.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="relative pb-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Form -->
        <div class="lg:col-span-3">
          <form action="https://formspree.io/f/your-form-id" method="POST" class="space-y-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-xs tracking-wider uppercase text-charcoal-400 mb-2">Full Name *</label>
                <input type="text" id="name" name="name" required class="w-full bg-charcoal-900 border border-charcoal-700 px-4 py-3 text-sm text-charcoal-100 placeholder-charcoal-600 focus:outline-none focus:border-brass-500 transition-colors" placeholder="Your name" />
              </div>
              <div>
                <label for="company" class="block text-xs tracking-wider uppercase text-charcoal-400 mb-2">Company *</label>
                <input type="text" id="company" name="company" required class="w-full bg-charcoal-900 border border-charcoal-700 px-4 py-3 text-sm text-charcoal-100 placeholder-charcoal-600 focus:outline-none focus:border-brass-500 transition-colors" placeholder="Company name" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label for="email" class="block text-xs tracking-wider uppercase text-charcoal-400 mb-2">Email *</label>
                <input type="email" id="email" name="email" required class="w-full bg-charcoal-900 border border-charcoal-700 px-4 py-3 text-sm text-charcoal-100 placeholder-charcoal-600 focus:outline-none focus:border-brass-500 transition-colors" placeholder="your@company.com" />
              </div>
              <div>
                <label for="phone" class="block text-xs tracking-wider uppercase text-charcoal-400 mb-2">Phone / WhatsApp</label>
                <input type="text" id="phone" name="phone" class="w-full bg-charcoal-900 border border-charcoal-700 px-4 py-3 text-sm text-charcoal-100 placeholder-charcoal-600 focus:outline-none focus:border-brass-500 transition-colors" placeholder="+86 123 4567 890" />
              </div>
            </div>

            <div>
              <label for="product" class="block text-xs tracking-wider uppercase text-charcoal-400 mb-2">Product Interest *</label>
              <select id="product" name="product" required class="w-full bg-charcoal-900 border border-charcoal-700 px-4 py-3 text-sm text-charcoal-300 focus:outline-none focus:border-brass-500 transition-colors">
                <option value="" disabled selected>Select product category</option>
                <option value="power-lift">Power Lift Recliner</option>
                <option value="sofa">Sofas & Sectionals</option>
                <option value="motion">Motion Furniture</option>
                <option value="swivel">Swivel Rocking Chair</option>
                <option value="accent">Accent Chairs</option>
                <option value="custom">Custom OEM/ODM Project</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-xs tracking-wider uppercase text-charcoal-400 mb-2">Your Inquiry *</label>
              <textarea id="message" name="message" rows="5" required class="w-full bg-charcoal-900 border border-charcoal-700 px-4 py-3 text-sm text-charcoal-100 placeholder-charcoal-600 focus:outline-none focus:border-brass-500 transition-colors resize-none" placeholder="Tell us about your project — product type, quantity, target market, timeline..."></textarea>
            </div>

            <button type="submit" class="btn-brass text-sm w-full md:w-auto justify-center">
              Send Inquiry
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
              </svg>
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="lg:col-span-2">
          <div class="bg-charcoal-900/50 border border-charcoal-800/50 p-8 space-y-8">
            <div>
              <h3 class="text-xs tracking-[0.2em] uppercase text-brass-400 font-semibold mb-4">Contact Information</h3>
              <div class="space-y-4 text-sm text-charcoal-400">
                <div>
                  <p class="text-charcoal-300 font-medium">Saikodu (Foshan) Trading Co., Ltd</p>
                  <p>Foshan, Guangdong, China</p>
                </div>
                <div>
                  <p class="text-xs tracking-wider uppercase text-charcoal-600 mb-1">Email</p>
                  <a href="mailto:info@skydohome.com" class="text-brass-300 no-underline hover:text-brass-400 transition-colors">info@skydohome.com</a>
                </div>
                <div>
                  <p class="text-xs tracking-wider uppercase text-charcoal-600 mb-1">Phone / WhatsApp</p>
                  <a href="tel:+861234567890" class="text-charcoal-300 no-underline hover:text-brass-300 transition-colors">+86 123 4567 890</a>
                </div>
              </div>
            </div>

            <div class="pt-6 border-t border-charcoal-800">
              <h3 class="text-xs tracking-[0.2em] uppercase text-brass-400 font-semibold mb-4">Quick Inquiry Tips</h3>
              <ul class="space-y-2 text-sm text-charcoal-500">
                <li class="flex items-start gap-2">
                  <span class="w-1 h-1 rounded-full bg-brass-500 mt-2 flex-shrink-0"></span>
                  Include target quantity for best pricing
                </li>
                <li class="flex items-start gap-2">
                  <span class="w-1 h-1 rounded-full bg-brass-500 mt-2 flex-shrink-0"></span>
                  Reference images or sketches help us quote accurately
                </li>
                <li class="flex items-start gap-2">
                  <span class="w-1 h-1 rounded-full bg-brass-500 mt-2 flex-shrink-0"></span>
                  Mention target market for compliance guidance
                </li>
                <li class="flex items-start gap-2">
                  <span class="w-1 h-1 rounded-full bg-brass-500 mt-2 flex-shrink-0"></span>
                  We respond within 24 hours on business days
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
