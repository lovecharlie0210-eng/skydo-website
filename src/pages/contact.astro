---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Get in Touch">
  <section class="pt-[120px] pb-20 bg-sand-50/50">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="max-w-2xl">
        <div class="accent-line"></div>
        <h1 class="mt-6 text-4xl md:text-6xl text-walnut-950 leading-tight">
          Let's Start a<br />
          <span class="italic text-walnut-500">Conversation</span>
        </h1>
        <p class="mt-4 text-sm text-charcoal-500 leading-relaxed font-light max-w-lg">
          Tell us about your project — product type, target market, volume, and timeline. We'll respond within 24 hours with a competitive quotation.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-28">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Form -->
        <div class="lg:col-span-3">
          <form action="https://formspree.io/f/your-form-id" method="POST" class="space-y-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-[11px] tracking-[0.15em] uppercase text-charcoal-500 font-medium mb-2">Full Name *</label>
                <input type="text" id="name" name="name" required class="w-full bg-white border border-sand-300 px-4 py-3 text-sm text-charcoal-800 placeholder-charcoal-400 focus:outline-none focus:border-walnut-400 transition-colors" placeholder="Your name" />
              </div>
              <div>
                <label for="company" class="block text-[11px] tracking-[0.15em] uppercase text-charcoal-500 font-medium mb-2">Company *</label>
                <input type="text" id="company" name="company" required class="w-full bg-white border border-sand-300 px-4 py-3 text-sm text-charcoal-800 placeholder-charcoal-400 focus:outline-none focus:border-walnut-400 transition-colors" placeholder="Company name" />
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label for="email" class="block text-[11px] tracking-[0.15em] uppercase text-charcoal-500 font-medium mb-2">Email *</label>
                <input type="email" id="email" name="email" required class="w-full bg-white border border-sand-300 px-4 py-3 text-sm text-charcoal-800 placeholder-charcoal-400 focus:outline-none focus:border-walnut-400 transition-colors" placeholder="your@company.com" />
              </div>
              <div>
                <label for="phone" class="block text-[11px] tracking-[0.15em] uppercase text-charcoal-500 font-medium mb-2">Phone / WhatsApp</label>
                <input type="text" id="phone" name="phone" class="w-full bg-white border border-sand-300 px-4 py-3 text-sm text-charcoal-800 placeholder-charcoal-400 focus:outline-none focus:border-walnut-400 transition-colors" placeholder="+86 123 4567 890" />
              </div>
            </div>
            <div>
              <label for="product" class="block text-[11px] tracking-[0.15em] uppercase text-charcoal-500 font-medium mb-2">Product Interest *</label>
              <select id="product" name="product" required class="w-full bg-white border border-sand-300 px-4 py-3 text-sm text-charcoal-600 focus:outline-none focus:border-walnut-400 transition-colors">
                <option value="" disabled selected>Select category</option>
                <option value="power-lift">Power Lift Recliner</option>
                <option value="sofa">Sofas & Sectionals</option>
                <option value="motion">Motion Furniture</option>
                <option value="swivel">Swivel Rocking Chair</option>
                <option value="accent">Accent Chairs</option>
                <option value="custom">Custom OEM/ODM Project</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-[11px] tracking-[0.15em] uppercase text-charcoal-500 font-medium mb-2">Your Inquiry *</label>
              <textarea id="message" name="message" rows="5" required class="w-full bg-white border border-sand-300 px-4 py-3 text-sm text-charcoal-800 placeholder-charcoal-400 focus:outline-none focus:border-walnut-400 transition-colors resize-none" placeholder="Tell us about your project — product type, quantity, target market, timeline..."></textarea>
            </div>
            <button type="submit" class="btn-primary">
              Send Inquiry
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
              </svg>
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="lg:col-span-2">
          <div class="bg-sand-50 border border-sand-200 p-8 space-y-8">
            <div>
              <h3 class="text-[11px] tracking-[0.2em] uppercase text-walnut-700 font-semibold mb-5">Contact Information</h3>
              <div class="space-y-5 text-sm text-charcoal-600 font-light">
                <div>
                  <p class="text-charcoal-800 font-medium">Saikodu (Foshan) Trading Co.</p>
                  <p>Foshan, Guangdong, China</p>
                </div>
                <div>
                  <p class="text-[10px] tracking-[0.15em] uppercase text-charcoal-400 font-semibold mb-1">Email</p>
                  <a href="mailto:info@skydohome.com" class="text-walnut-700 no-underline hover:text-walnut-600 transition-colors">info@skydohome.com</a>
                </div>
                <div>
                  <p class="text-[10px] tracking-[0.15em] uppercase text-charcoal-400 font-semibold mb-1">Phone / WhatsApp</p>
                  <a href="tel:+861234567890" class="text-charcoal-700 no-underline hover:text-walnut-600 transition-colors">+86 123 4567 890</a>
                </div>
              </div>
            </div>
            <div class="pt-6 border-t border-sand-200">
              <h3 class="text-[11px] tracking-[0.2em] uppercase text-walnut-700 font-semibold mb-4">Quick Tips</h3>
              <ul class="space-y-3 text-sm text-charcoal-500 font-light">
                <li class="flex items-start gap-2">
                  <span class="w-1 h-1 bg-walnut-300 mt-2 flex-shrink-0"></span>
                  Include target quantity for best pricing
                </li>
                <li class="flex items-start gap-2">
                  <span class="w-1 h-1 bg-walnut-300 mt-2 flex-shrink-0"></span>
                  Reference images or sketches help us quote accurately
                </li>
                <li class="flex items-start gap-2">
                  <span class="w-1 h-1 bg-walnut-300 mt-2 flex-shrink-0"></span>
                  Mention target market for compliance guidance
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
