---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n/translations';
import { locales } from '../../i18n/languages';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang] || translations.en;
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<Layout title="Products — Upholstered Furniture" lang={lang}>
  <section class="pt-[120px] pb-20 bg-sand-50/50">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="max-w-2xl">
        <div class="accent-line"></div>
        <h1 class="mt-6 text-4xl md:text-6xl text-walnut-950 leading-tight">
          {t.productsPage.heading}<br />
          <span class="italic text-walnut-500">{t.productsPage.headingItalic}</span>
        </h1>
        <p class="mt-4 text-sm text-charcoal-500 leading-relaxed font-light max-w-lg">{t.productsPage.subtitle}</p>
      </div>
    </div>
  </section>

  <section class="pb-28">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 -mt-8">
        {t.productsPage.categories.map((cat) => (
          <div class="bg-white border border-sand-200 overflow-hidden transition-all duration-300 card-hover">
            <div class="aspect-[4/3] img-upload-area flex items-center justify-center p-8">
              <div class="text-center">
                <svg class="w-10 h-10 mx-auto text-sand-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                </svg>
                <p class="text-xs text-walnut-400 uppercase tracking-wider font-medium">{t.productsPage.placeholder}</p>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-lg font-heading text-walnut-800">{cat.name}</h3>
              <p class="mt-2 text-xs text-charcoal-500 leading-relaxed font-light">{cat.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-sand-50 border-t border-sand-200">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div class="accent-line mx-auto"></div>
      <h2 class="mt-5 text-2xl md:text-4xl text-walnut-950">
        {t.productsPage.ctaHeading} <span class="italic text-walnut-500">{t.productsPage.ctaHeadingItalic}</span> {t.productsPage.ctaHeadingEnd}
      </h2>
      <p class="mt-4 text-sm text-charcoal-500 font-light">{t.productsPage.ctaText}</p>
      <a href={`${prefix}/contact`} class="btn-primary mt-8">{t.productsPage.ctaButton}</a>
    </div>
  </section>
</Layout>
