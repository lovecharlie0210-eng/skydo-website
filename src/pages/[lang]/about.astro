---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n/translations';
import { locales } from '../../i18n/languages';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang] || translations.en;
---

<Layout title="About — Our Factory" lang={lang}>
  <section class="pt-[120px] pb-20 bg-sand-50/50">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="max-w-2xl">
        <div class="accent-line"></div>
        <h1 class="mt-6 text-4xl md:text-6xl text-walnut-950 leading-tight">
          {t.aboutPage.heading}<br />
          <span class="italic text-walnut-500">{t.aboutPage.headingItalic}</span>
        </h1>
      </div>
    </div>
  </section>

  <section class="pb-28">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <h2 class="text-2xl md:text-4xl font-heading text-walnut-950">
            {t.aboutPage.sectionHeading}<br />
            <span class="italic text-walnut-500">{t.aboutPage.sectionHeadingItalic}</span>
          </h2>
          <div class="mt-6 space-y-4 text-sm text-charcoal-500 leading-relaxed font-light">
            {t.aboutPage.paragraphs.map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] img-upload-area flex items-center justify-center">
            <div class="text-center">
              <svg class="w-24 h-24 mx-auto text-sand-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 21h18M3.75 3v18M20.25 3v18M6.75 3h10.5M6.75 7.5h.75m-.75 3.75h.75m-.75 3.75h.75m3-11.25h.75m-.75 3.75h.75m-.75 3.75h.75m3-11.25h.75m-.75 3.75h.75m-.75 3.75h.75M6.75 21V3m10.5 18V3" />
              </svg>
              <p class="text-sm text-walnut-500 font-medium">{t.aboutPage.imagePlaceholder}</p>
              <p class="text-xs text-charcoal-400 mt-1">{t.aboutPage.imageHint}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-sand-50">
    <div class="max-w-4xl mx-auto px-6 xl:px-0">
      <div class="text-center">
        <div class="accent-line mx-auto"></div>
        <h2 class="mt-5 text-2xl md:text-4xl font-heading text-walnut-950">
          {t.aboutPage.timelineHeading} <span class="italic text-walnut-500">{t.aboutPage.timelineHeadingItalic}</span>
        </h2>
      </div>
      <div class="mt-14">
        {t.aboutPage.timeline.map((item, i) => (
          <div class="flex gap-6">
            <div class="flex flex-col items-center">
              <div class="w-3 h-3 rounded-full border-2 border-walnut-400 bg-white mt-1"></div>
              {i < t.aboutPage.timeline.length - 1 && <div class="w-px flex-1 bg-sand-200"></div>}
            </div>
            <div class="pb-10">
              <span class="text-xs tracking-[0.15em] uppercase text-walnut-600 font-semibold">{item.year}</span>
              <p class="mt-1.5 text-sm text-charcoal-600 leading-relaxed font-light">{item.event}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="max-w-4xl mx-auto px-6 xl:px-0 text-center">
      <div class="accent-line mx-auto"></div>
      <h2 class="mt-5 text-2xl md:text-4xl font-heading text-walnut-950">
        {t.aboutPage.certHeading} <span class="italic text-walnut-500">{t.aboutPage.certHeadingItalic}</span>
      </h2>
      <p class="mt-3 text-sm text-charcoal-500 font-light mb-10">{t.aboutPage.certSub}</p>
      <div class="flex flex-wrap justify-center gap-3">
        {t.aboutPage.certs.map((cert) => (
          <span class="px-5 py-2.5 border border-sand-300 text-xs text-charcoal-600 bg-sand-50 tracking-wider font-medium">{cert}</span>
        ))}
      </div>
    </div>
  </section>
</Layout>
