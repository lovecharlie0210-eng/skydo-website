---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n/translations';
import { locales } from '../../i18n/languages';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang] || translations.en;
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<Layout title="Why Skydo — OEM/ODM Advantages" lang={lang}>
  <section class="pt-[120px] pb-20 bg-sand-50/50">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="max-w-2xl">
        <div class="accent-line"></div>
        <h1 class="mt-6 text-4xl md:text-6xl text-walnut-950 leading-tight">
          {t.whyUsPage.heading}<br />
          <span class="italic text-walnut-500">{t.whyUsPage.headingItalic}</span>
        </h1>
        <p class="mt-4 text-sm text-charcoal-500 leading-relaxed font-light max-w-lg">{t.whyUsPage.subtitle}</p>
      </div>
    </div>
  </section>

  <section class="pb-28">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 -mt-8">
        {t.whyUsPage.advantages.map((adv) => (
          <div class="bg-white border border-sand-200 p-8 card-hover">
            <svg class="w-7 h-7 text-walnut-500 mb-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={adv.icon} />
            </svg>
            <h3 class="text-lg font-heading text-walnut-800">{adv.title}</h3>
            <p class="mt-3 text-xs text-charcoal-500 leading-relaxed font-light">{adv.desc}</p>
            <ul class="mt-4 space-y-1.5">
              {adv.details.map((d) => (
                <li class="flex items-center gap-2 text-[11px] text-charcoal-400">
                  <span class="w-1 h-1 bg-walnut-300 rounded-full"></span>
                  {d}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-sand-50 border-t border-sand-200">
    <div class="max-w-5xl mx-auto px-6 xl:px-0">
      <div class="text-center">
        <div class="accent-line mx-auto"></div>
        <h2 class="mt-5 text-2xl md:text-4xl font-heading text-walnut-950">
          {t.whyUsPage.processHeading} <span class="italic text-walnut-500">{t.whyUsPage.processHeadingItalic}</span>
        </h2>
      </div>
      <div class="mt-14 grid grid-cols-1 md:grid-cols-4 gap-10">
        {t.whyUsPage.process.map((item) => (
          <div class="text-center">
            <span class="text-5xl font-heading text-walnut-200/70">{item.step}</span>
            <h3 class="mt-4 text-lg font-heading text-walnut-800">{item.title}</h3>
            <p class="mt-2 text-xs text-charcoal-500 font-light">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href={`${prefix}/contact`} class="btn-primary">{t.whyUsPage.processCta}</a>
      </div>
    </div>
  </section>
</Layout>
