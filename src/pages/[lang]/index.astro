---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n/translations';
import { locales } from '../../i18n/languages';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang] || translations.en;
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<Layout title="Premium OEM/ODM Furniture Manufacturer" lang={lang}>
  <section class="relative min-h-screen flex items-center pt-[72px] overflow-hidden bg-sand-50">
    <div class="absolute inset-0 bg-gradient-to-br from-sand-50 via-white to-sand-100"></div>
    <div class="absolute top-1/3 right-0 w-[500px] h-[500px] bg-sand-200/40 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-0 left-1/4 w-[400px] h-[400px] bg-walnut-200/20 rounded-full blur-[80px]"></div>
    <div class="relative max-w-7xl mx-auto px-6 xl:px-0 py-20 w-full">
      <div class="max-w-3xl">
        <div class="accent-line mb-8 animate-scale-in"></div>
        <p class="text-xs tracking-[0.2em] uppercase text-walnut-600 font-medium animate-fade-in-up">{t.hero.badge}</p>
        <h1 class="mt-5 text-5xl md:text-7xl lg:text-8xl text-walnut-950 leading-[1.05] animate-fade-in-up delay-100">{t.hero.headline}<br><span class="italic text-walnut-500">{t.hero.headlineItalic}</span></h1>
        <p class="mt-6 text-lg text-charcoal-500 leading-relaxed max-w-xl font-light animate-fade-in-up delay-200">{t.hero.subtitle}</p>
        <div class="mt-10 flex flex-wrap gap-4 animate-fade-in-up delay-300">
          <a href={`${prefix}/contact`} class="btn-primary">{t.hero.ctaPrimary}</a>
          <a href={`${prefix}/products`} class="btn-outline">{t.hero.ctaSecondary}</a>
        </div>
        <div class="mt-16 flex flex-wrap items-center gap-8 animate-fade-in-up delay-400">
          <div class="flex items-center gap-3"><span class="w-8 h-px bg-sand-300"></span><span class="text-[11px] tracking-wider uppercase text-charcoal-400 font-medium">{t.hero.trustBSCI}</span></div>
          <div class="flex items-center gap-3"><span class="w-8 h-px bg-sand-300"></span><span class="text-[11px] tracking-wider uppercase text-charcoal-400 font-medium">{t.hero.trustISO}</span></div>
          <div class="flex items-center gap-3"><span class="w-8 h-px bg-sand-300"></span><span class="text-[11px] tracking-wider uppercase text-charcoal-400 font-medium">{t.hero.trustUL}</span></div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="grid grid-cols-2 md:grid-cols-4 border-l border-sand-200">
        {t.stats.map((stat) => (
          <div class="py-14 px-8 border-r border-b border-sand-200 text-center">
            <p class="text-4xl md:text-5xl font-heading text-walnut-700">{stat.value}</p>
            <p class="mt-2 text-[11px] tracking-[0.15em] uppercase text-charcoal-400 font-medium">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-28 md:py-36">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="text-center max-w-xl mx-auto">
        <div class="accent-line mx-auto"></div>
        <h2 class="mt-6 text-3xl md:text-5xl text-walnut-950">{t.categories.heading}<br><span class="italic text-walnut-500">{t.categories.headingItalic}</span></h2>
        <p class="mt-4 text-sm text-charcoal-500 leading-relaxed font-light">{t.categories.subtitle}</p>
      </div>
      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-5">
        {t.categories.items.map((item) => (
          <a href={`${prefix}/products`} class="group cursor-pointer no-underline">
            <div class="aspect-[4/5] img-upload-area flex items-center justify-center">
              <div class="text-center p-8">
                <svg class="w-12 h-12 mx-auto text-sand-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m8.25-3.75l-1.5 3.75m9-3.75l1.5 3.75M9 13.5h6" />
                </svg>
                <p class="text-xs tracking-[0.2em] uppercase text-walnut-500 font-medium">{item.num}</p>
                <h3 class="mt-3 text-xl md:text-2xl font-heading text-walnut-800 group-hover:text-walnut-600 transition-colors">{item.title}</h3>
                <p class="mt-2 text-xs text-charcoal-400 leading-relaxed max-w-xs font-light mx-auto">{item.desc}</p>
                <span class="mt-4 inline-block text-[10px] tracking-wider uppercase text-walnut-400 border border-dashed border-walnut-300 px-3 py-1 rounded-sm">{item.placeholder}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-28 md:py-36 bg-sand-50">
    <div class="max-w-7xl mx-auto px-6 xl:px-0">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="accent-line"></div>
          <h2 class="mt-6 text-3xl md:text-5xl text-walnut-950 leading-tight">{t.partner.heading}<br><span class="italic text-walnut-500">{t.partner.headingItalic}</span></h2>
          <p class="mt-6 text-sm text-charcoal-500 leading-relaxed font-light">{t.partner.subtitle}</p>
          <ul class="mt-10 space-y-4">
            {t.partner.bullets.map((bullet) => (
              <li class="flex items-start gap-3 text-sm text-charcoal-700">
                <span class="mt-1.5 w-1.5 h-1.5 bg-walnut-400 flex-shrink-0"></span>{bullet}
              </li>
            ))}
          </ul>
          <a href={`${prefix}/why-us`} class="btn-outline mt-10">{t.partner.cta}</a>
        </div>
        <div class="relative">
          <div class="aspect-square w-full max-w-md mx-auto img-upload-area flex items-center justify-center">
            <div class="text-center">
              <svg class="w-16 h-16 mx-auto text-sand-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
              </svg>
              <p class="text-sm text-walnut-500 font-medium">{t.partner.imagePlaceholder}</p>
              <p class="text-xs text-charcoal-400 mt-1">{t.partner.imageHint}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-28 md:py-36">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div class="accent-line mx-auto"></div>
      <h2 class="mt-6 text-3xl md:text-5xl text-walnut-950 leading-tight">{t.cta.heading}<br><span class="italic text-walnut-500">{t.cta.headingItalic}</span></h2>
      <p class="mt-6 text-sm text-charcoal-500 leading-relaxed font-light max-w-md mx-auto">{t.cta.subtitle}</p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href={`${prefix}/contact`} class="btn-primary">{t.cta.ctaPrimary}</a>
        <a href={`${prefix}/about`} class="btn-outline">{t.cta.ctaSecondary}</a>
      </div>
    </div>
  </section>
</Layout>
